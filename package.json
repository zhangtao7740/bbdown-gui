{
  "name": "bbdown-gui",
  "version": "0.2.1",
  "description": "Electron GUI for BBDown.",
  "private": false,
  "license": "MIT",
  "author": "zhangtao7740",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhangtao7740/bbdown-gui.git"
  },
  "bugs": {
    "url": "https://github.com/zhangtao7740/bbdown-gui/issues"
  },
  "homepage": "https://github.com/zhangtao7740/bbdown-gui#readme",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-preload.mjs && vite",
    "build": "tsc -b && vite build && node scripts/build-preload.mjs",
    "build:icons": "node scripts/generate-icons.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack": "npm run build:icons && npm run build && electron-builder --dir",
    "pack:mac": "npm run pack:mac:universal",
    "pack:mac:arm64": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir --arm64",
    "pack:mac:x64": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir --x64",
    "pack:mac:universal": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --dir --universal",
    "dist": "npm run build:icons && npm run build && electron-builder",
    "dist:mac": "npm run dist:mac:universal",
    "dist:mac:arm64": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --arm64",
    "dist:mac:x64": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --x64",
    "dist:mac:universal": "npm run build:icons && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --universal"
  },
  "build": {
    "appId": "com.bbdown.gui",
    "productName": "BBDown GUI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "sharp": "^0.34.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
